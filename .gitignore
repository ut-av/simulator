# Unity Git Setup
/simulator/unity/[Ll]ibrary/
/simulator/unity/[Tt]emp/
/simulator/unity/[Oo]bj/
/simulator/unity/[Bb]uild/
/simulator/unity/[Bb]uilds/
/simulator/unity/.[Vv][Ss][Cc]ode/
/simulator/unity/.[Vv][Ss]/
/simulator/unity/Assets/AssetStoreTools*

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Generated if you use the new UIElements (either for editor or runtime in 2020)
/simulator/unity/[Uu][Ii][Ee]lements[Ss]chema/
# Upgrade and package manager logs for Unity etc. (and some asset logs in 2020 too now)
/simulator/unity/[Ll]ogs/
# Ignore UserSettings, we most likely don't want to sync these across users
/simulator/unity/[Uu]ser[Ss]ettings/

# Autogenerated VS/MD solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
unitylog.txt

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.unitypackage

# Mac stuff
.DS_Store
.bak
.BAK

# VS code
/simulator/unity/.vs
/simulator/unity/.vscode

# Other
*.pyc
*.h5
dataset
/camera_a.png
/camera_b.png
/simulator/unity/Builds
/simulator/build
/src/camera_a.png
/src/camera_b.png
/simulator/unity/Assets/StreamingAssets
/simulator/unity/Assets/AssetBundles
*.egg-info*

# Model outputs
wandb/
output/

resources
logs/
